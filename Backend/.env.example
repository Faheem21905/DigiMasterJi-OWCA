# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/digimasterji?retryWrites=true&w=majority

# JWT Configuration
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# App Configuration
APP_NAME=DigiMasterji
DEBUG=True

# Ollama LLM Settings
OLLAMA_BASE_URL=http://localhost:11434

# Model to use for online chat (larger model with full capabilities)
OLLAMA_MODEL=gemma3:12b

# Offline model for limited/no network scenarios (smaller 270M param model)
# Use gemma3:1b for the ~270M parameter variant
OLLAMA_OFFLINE_MODEL=gemma3:1b

# Enable/disable offline chat support
OFFLINE_CHAT_ENABLED=true

# AI Model Settings (Optional)
# Device for running AI models
# Options: cuda:0, cpu
# AI_DEVICE=cuda:0

# ===== STT (Speech-to-Text) Settings =====
# STT Provider: 'local' (uses local Whisper) or 'deepgram' (uses Deepgram cloud API)
STT_PROVIDER=deepgram

# Model size for local Whisper: tiny, base, small, medium, large
STT_MODEL_SIZE=medium

# Language detection mode: 'profile' (use user's preferred_language) or 'auto' (auto-detect from audio)
STT_LANGUAGE_MODE=auto

# Deepgram Settings (required if STT_PROVIDER=deepgram)
DEEPGRAM_API_KEY=your-deepgram-api-key
# Deepgram Whisper model: whisper, whisper-tiny, whisper-base, whisper-small, whisper-medium, whisper-large
DEEPGRAM_MODEL=whisper-large

# TTS model
# TTS_MODEL=ai4bharat/indic-parler-tts

# RAG Configuration Parameters:
CHAT_HISTORY_LIMIT=10 # Number of previous messages for context
RAG_CHUNKS_LIMIT=5 # Number of knowledge chunks to retrieve
RAG_MIN_SCORE=0.3 # Minimum similarity score threshold
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024
SKIP_STARTUP_QUIZ=true

# Sync Configuration
SYNC_DEFAULT_DAYS=180  # Default number of days of messages to sync
SYNC_MAX_DAYS=365      # Maximum allowed days for sync